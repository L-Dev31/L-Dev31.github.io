  "start_scene": "intro",
  "scenes": {
    "intro": {
      "actions": [
        {
          "type": "transition",
          "environment": "office"
        },
        {
          "type": "dialogue",
          "character": "narrator",
          "text": {
            "fr": "3 octobre. Une pluie battante s'abat sur la ville. Un appel téléphonique vient briser le silence du bureau.",
            "en": "October 3rd. Heavy rain pounds the city. A phone call breaks the silence of the office."
          }
        },
        {
          "type": "dialogue",
          "character": "detective",
          "text": {
            "fr": "Détective Vance, j'écoute... Un meurtre au manoir Blackwood ? J'arrive immédiatement.",
            "en": "Detective Vance speaking... A murder at the Blackwood mansion? I'm on my way."
          }
        },
        {
          "type": "transition",
          "environment": "crime_scene"
        },
        {
          "type": "dialogue",
          "character": "detective",
          "text": {
            "fr": "La victime gît au sol, une lettre froissée dans la main. Quelque chose ne colle pas dans cette scène.",
            "en": "The victim lies on the floor, a crumpled letter in hand. Something feels off about this scene."
          }
        },
        {
          "type": "dialogue",
          "character": "witness",
          "text": {
            "fr": "Détective ! J'ai tout vu. Enfin, presque tout. C'était horrible !",
            "en": "Detective! I saw everything. Well, almost. It was horrible!"
          }
        },
        {
          "type": "choice",
          "question": {
            "fr": "Par où commencer l'enquête ?",
            "en": "Where to begin the investigation?"
          },
          "options": [
            {
              "text": {
                "fr": "Interroger Mme Hartley",
                "en": "Question Mrs. Hartley"
              },
              "goto": "question_witness"
            },
            {
              "text": {
                "fr": "Examiner la lettre",
                "en": "Examine the letter"
              },
              "goto": "examine_letter"
            }
          ]
        }
      ]
    },
    "question_witness": {
      "actions": [
        {
          "type": "transition",
          "environment": "interrogation"
        },
        {
          "type": "dialogue",
          "character": "detective",
          "text": {
            "fr": "Madame Hartley, racontez-moi ce que vous avez vu, dans les moindres détails.",
            "en": "Mrs. Hartley, tell me exactly what you saw. Spare no detail."
          }
        },
        {
          "type": "dialogue",
          "character": "witness",
          "text": {
            "fr": "Une silhouette sombre... elle est passée près de la fenêtre vers minuit. Grande, mince. Je n'ai pas vu son visage.",
            "en": "A dark figure... it passed by the window around midnight. Tall, slim. I didn't see the face."
          }
        },
        {
          "type": "dialogue",
          "character": "detective",
          "text": {
            "fr": "Cette description correspond à M. Blackwood lui-même. Étrange.",
            "en": "That description matches Mr. Blackwood himself. Strange."
          }
        },
        {
          "type": "choice",
          "question": {
            "fr": "Que faire maintenant ?",
            "en": "What's the next move?"
          },
          "options": [
            {
              "text": {
                "fr": "Confronter M. Blackwood",
                "en": "Confront Mr. Blackwood"
              },
              "goto": "confront_suspect"
            },
            {
              "text": {
                "fr": "Retourner sur la scène",
                "en": "Return to the crime scene"
              },
              "goto": "examine_letter"
            }
          ]
        }
      ]
    },
    "examine_letter": {
      "actions": [
        {
          "type": "transition",
          "environment": "crime_scene"
        },
        {
          "type": "dialogue",
          "character": "detective",
          "text": {
            "fr": "La lettre est signée 'B'. Une menace claire : 'Tu paieras pour ce que tu as fait.'",
            "en": "The letter is signed 'B'. A clear threat: 'You will pay for what you did.'"
          }
        },
        {
          "type": "dialogue",
          "character": "narrator",
          "text": {
            "fr": "L'écriture est tremblante. Celui qui a écrit ceci était bouleversé... ou jouait un rôle.",
            "en": "The handwriting is shaky. Whoever wrote this was distraught... or pretending to be."
          }
        },
        {
          "type": "dialogue",
          "character": "detective",
          "text": {
            "fr": "Il est temps d'aller voir le maître des lieux.",
            "en": "Time to pay a visit to the master of the house."
          }
        },
        {
          "type": "goto",
          "scene": "confront_suspect"
        }
      ]
    },
    "confront_suspect": {
      "actions": [
        {
          "type": "transition",
          "environment": "mansion"
        },
        {
          "type": "dialogue",
          "character": "suspect",
          "text": {
            "fr": "Détective Vance. Je vous attendais. Mais vous perdez votre temps avec moi.",
            "en": "Detective Vance. I was expecting you. But you're wasting your time with me."
          }
        },
        {
          "type": "dialogue",
          "character": "detective",
          "text": {
            "fr": "Cette lettre porte votre initiale. Mme Hartley vous a vu la nuit du crime. Expliquez-vous.",
            "en": "This letter bears your initial. Mrs. Hartley saw you the night of the crime. Explain yourself."
          }
        },
        {
          "type": "dialogue",
          "character": "suspect",
          "text": {
            "fr": "(Long silence) ... Vous ne comprenez pas. Je voulais juste lui parler. Je ne pensais pas que...",
            "en": "(Long silence) ... You don't understand. I just wanted to talk to him. I never thought that..."
          }
        },
        {
          "type": "dialogue",
          "character": "narrator",
          "text": {
            "fr": "L'affaire Blackwood prend une tournure inattendue. À suivre.",
            "en": "The Blackwood case takes an unexpected turn. To be continued."
          }
        },
        {
          "type": "end"
        }
      ]
    }
  }
}